# Base URL of the backend REST API, as reached from the BROWSER —
# not from inside another Docker container. The browser cannot resolve
# Docker-internal hostnames like `web_backend`, so use localhost (same
# machine) or your host's LAN IP (testing from a phone/other device).
VITE_API_BASE_URL=http://localhost:8000

# Base URL of the backend WebSocket endpoint. Same rule as above.
VITE_WS_BASE_URL=ws://localhost:8000

# How often (in seconds) a camera frame is sent over the WebSocket
# during face verification.
#
# Accepted values: 1 | 0.5 | 0.25 | ALL_TIME
#   1        -> one frame every second
#   0.5      -> one frame every 500ms
#   0.25     -> one frame every 250ms
#   ALL_TIME -> stream every animation frame continuously
VITE_FACE_FRAME_INTERVAL=1
